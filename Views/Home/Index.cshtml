<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Curator. — Premium Fashion</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;600;700&display=swap" rel="stylesheet">
<!-- SF Pro Display fallback via system font stack -->

<style>
/* =============================================
   APPLE-STYLE DESIGN SYSTEM
   Custom CSS only — Bootstrap handles layout
   ============================================= */

:root {
  --sf: -apple-system, 'SF Pro Display', BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --white: #ffffff;
  --gray-1: #f5f5f7;   /* Apple's page bg */
  --gray-2: #e8e8ed;
  --gray-3: #d1d1d6;
  --gray-4: #8e8e93;
  --gray-5: #3a3a3c;
  --black:  #1d1d1f;   /* Apple's text black */
  --blue:   #0071e3;   /* Apple blue */
  --blue-h: #0077ed;
  --radius-sm:  12px;
  --radius-md:  18px;
  --radius-lg:  24px;
  --radius-xl:  32px;
  --shadow-xs: 0 2px 8px rgba(0,0,0,0.06);
  --shadow-sm: 0 4px 16px rgba(0,0,0,0.08);
  --shadow-md: 0 8px 32px rgba(0,0,0,0.10);
  --shadow-lg: 0 20px 60px rgba(0,0,0,0.12);
}

/* ---- Base ---- */
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--sf);
  background: var(--gray-1);
  color: var(--black);
  -webkit-font-smoothing: antialiased;
  padding-bottom: 90px;
}
a { text-decoration: none; color: inherit; }

/* =============================================
   NAVBAR — Apple.com style frosted glass
   ============================================= */
.apple-nav {
  background: rgba(255,255,255,0.72);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1px solid rgba(0,0,0,0.08);
  height: 56px;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
}
.apple-nav .nav-brand {
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--black);
}
.apple-nav .nav-link-item {
  font-size: 0.82rem;
  color: var(--black);
  opacity: 0.85;
  transition: opacity 0.2s;
  letter-spacing: -0.01em;
  padding: 0 10px;
}
.apple-nav .nav-link-item:hover { opacity: 1; }
.apple-nav .nav-link-item.active { opacity: 1; font-weight: 600; }
.nav-icon-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px 8px;
  border-radius: 50%;
  color: var(--black);
  font-size: 1.1rem;
  transition: background 0.15s;
  position: relative;
}
.nav-icon-btn:hover { background: rgba(0,0,0,0.06); }
.cart-badge {
  position: absolute;
  top: 2px; right: 2px;
  background: var(--blue);
  color: #fff;
  font-size: 0.55rem;
  font-weight: 700;
  width: 16px; height: 16px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 2px solid rgba(255,255,255,0.8);
}

/* =============================================
   HERO — Full cinematic, Apple product launch feel
   ============================================= */
.apple-hero {
  min-height: 100vh;
  background: var(--black);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 56px;
}
.apple-hero img.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0.55;
  transform: scale(1.03);
  transition: transform 8s ease;
}
.apple-hero:hover img.hero-bg { transform: scale(1.0); }
.hero-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 100%);
}
.hero-gradient-bottom {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 260px;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
}
.hero-text-block {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 820px;
  padding: 0 24px;
  animation: heroFadeUp 1.1s cubic-bezier(0.16,1,0.3,1) both;
}
@@keyframes heroFadeUp {
  from { opacity: 0; transform: translateY(32px); }
  to   { opacity: 1; transform: translateY(0); }
}
.hero-eyebrow {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 16px;
  display: block;
}
.hero-title {
  font-size: clamp(2.8rem, 7vw, 5.6rem);
  font-weight: 700;
  line-height: 1.0;
  letter-spacing: -0.04em;
  color: #ffffff;
  margin-bottom: 20px;
}
.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.25rem);
  font-weight: 400;
  color: rgba(255,255,255,0.72);
  margin-bottom: 36px;
  letter-spacing: -0.01em;
}
.hero-actions {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}

/* =============================================
   BUTTONS — Apple-exact pill style
   ============================================= */
.btn-apple-blue {
  background: var(--blue);
  color: #fff;
  border: none;
  border-radius: 980px;
  padding: 12px 28px;
  font-size: 0.95rem;
  font-weight: 500;
  font-family: var(--sf);
  letter-spacing: -0.01em;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-apple-blue:hover { background: var(--blue-h); transform: scale(1.02); color: #fff; }
.btn-apple-blue:active { transform: scale(0.98); }

.btn-apple-ghost {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 980px;
  padding: 12px 28px;
  font-size: 0.95rem;
  font-weight: 500;
  font-family: var(--sf);
  letter-spacing: -0.01em;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-apple-ghost:hover { background: rgba(255,255,255,0.25); transform: scale(1.02); color: #fff; }

.btn-apple-dark {
  background: var(--black);
  color: #fff;
  border: none;
  border-radius: 980px;
  padding: 12px 28px;
  font-size: 0.9rem;
  font-weight: 500;
  font-family: var(--sf);
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-apple-dark:hover { background: var(--gray-5); transform: scale(1.02); color: #fff; }

.btn-apple-outline {
  background: transparent;
  color: var(--blue);
  border: 1.5px solid var(--blue);
  border-radius: 980px;
  padding: 11px 26px;
  font-size: 0.9rem;
  font-weight: 500;
  font-family: var(--sf);
  cursor: pointer;
  transition: all 0.2s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-apple-outline:hover { background: var(--blue); color: #fff; transform: scale(1.02); }

/* =============================================
   SECTION LAYOUT — Apple generous spacing
   ============================================= */
.apple-section {
  padding: 96px 0;
  background: var(--white);
}
.apple-section-gray { background: var(--gray-1); }
.apple-section-dark { background: var(--black); }
.section-eyebrow {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue);
  display: block;
  margin-bottom: 10px;
}
.section-title {
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--black);
}
.section-title-white { color: #fff; }
.section-sub {
  font-size: 1rem;
  color: var(--gray-4);
  letter-spacing: -0.01em;
  margin-top: 8px;
}
.section-sub-white { color: rgba(255,255,255,0.55); }

/* =============================================
   MARQUEE BRAND STRIP
   ============================================= */
.brand-strip {
  background: var(--black);
  padding: 20px 0;
  overflow: hidden;
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.marquee-track { display: flex; white-space: nowrap; animation: marquee 22s linear infinite; }
@@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.brand-item {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.28);
  padding: 0 40px;
  white-space: nowrap;
}

/* =============================================
   PRODUCT CARDS — Apple card aesthetic
   ============================================= */
.apple-card {
  background: var(--white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease;
  box-shadow: var(--shadow-xs);
}
.apple-card:hover {
  transform: translateY(-6px) scale(1.01);
  box-shadow: var(--shadow-lg);
}
.apple-card-dark {
  background: #1c1c1e;
  border-radius: var(--radius-xl);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease;
}
.apple-card-dark:hover {
  transform: translateY(-6px) scale(1.01);
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.card-img-wrap {
  overflow: hidden;
  background: var(--gray-1);
}
.card-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
}
.apple-card:hover .card-img-wrap img,
.apple-card-dark:hover .card-img-wrap img {
  transform: scale(1.07);
}
.card-body-apple {
  padding: 18px 20px 22px;
}
.card-label {
  font-size: 0.72rem;
  color: var(--gray-4);
  font-weight: 500;
  letter-spacing: 0.01em;
  margin-bottom: 4px;
  display: block;
}
.card-name {
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--black);
  margin-bottom: 6px;
}
.card-name-white { color: #fff; }
.card-price {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--gray-4);
}
.card-price-highlight {
  font-weight: 600;
  color: var(--black);
}

/* Wishlist button on card */
.card-wish-btn {
  position: absolute;
  top: 14px; right: 14px;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(8px);
  border: none;
  border-radius: 50%;
  width: 34px; height: 34px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.2s, transform 0.2s, background 0.2s;
  color: var(--black);
  font-size: 0.9rem;
  z-index: 2;
}
.apple-card:hover .card-wish-btn,
.apple-card-dark:hover .card-wish-btn { opacity: 1; transform: scale(1); }
.card-wish-btn:hover { background: rgba(255,255,255,1); color: #e53935; }

/* Discount pill */
.discount-pill {
  position: absolute;
  top: 14px; left: 14px;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(6px);
  color: #fff;
  font-size: 0.68rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 980px;
  letter-spacing: 0.02em;
  z-index: 2;
}

/* =============================================
   FEATURED BENTO GRID
   ============================================= */
.bento-grid { display: grid; gap: 16px; }
.bento-large { grid-column: span 8; }
.bento-small { grid-column: span 4; }
@@media (max-width: 767px) {
  .bento-large, .bento-small { grid-column: span 12; }
}

/* =============================================
   FLASH SALE
   ============================================= */
.countdown-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 980px;
  padding: 10px 22px;
  backdrop-filter: blur(10px);
}
.cd-sep { color: rgba(255,255,255,0.4); font-weight: 300; font-size: 1.3rem; }
.cd-block { text-align: center; min-width: 36px; }
.cd-num {
  font-size: 1.4rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.03em;
  line-height: 1;
}
.cd-label { font-size: 0.6rem; color: rgba(255,255,255,0.4); letter-spacing: 0.1em; text-transform: uppercase; }

/* =============================================
   TOP RATED — Star ratings
   ============================================= */
.stars { color: #ff9f0a; font-size: 0.72rem; letter-spacing: 1px; }
.rating-count { font-size: 0.75rem; color: var(--gray-4); }

/* =============================================
   ADD TO CART quick action row
   ============================================= */
.quick-add {
  display: flex;
  gap: 8px;
  padding: 0 20px 18px;
}
.quick-add-btn {
  flex: 1;
  background: var(--blue);
  color: #fff;
  border: none;
  border-radius: 980px;
  padding: 9px 14px;
  font-size: 0.8rem;
  font-weight: 600;
  font-family: var(--sf);
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.quick-add-btn:hover { background: var(--blue-h); transform: scale(1.02); }
.quick-bag-btn {
  background: var(--gray-1);
  color: var(--black);
  border: none;
  border-radius: 50%;
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: 0.95rem;
  transition: background 0.2s;
}
.quick-bag-btn:hover { background: var(--gray-2); }

/* =============================================
   NEWSLETTER — Apple email section
   ============================================= */
.apple-input {
  background: var(--gray-1);
  border: 1.5px solid var(--gray-2);
  border-radius: 980px;
  padding: 14px 22px;
  font-size: 0.95rem;
  font-family: var(--sf);
  color: var(--black);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  width: 100%;
}
.apple-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(0,113,227,0.12);
  background: var(--white);
}
.apple-input::placeholder { color: var(--gray-4); }

/* =============================================
   FOOTER
   ============================================= */
.apple-footer {
  background: var(--gray-1);
  border-top: 1px solid var(--gray-2);
  padding: 48px 0 24px;
}
.footer-col-title {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--black);
  letter-spacing: 0.02em;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.footer-link {
  font-size: 0.82rem;
  color: var(--gray-4);
  display: block;
  margin-bottom: 10px;
  transition: color 0.15s;
}
.footer-link:hover { color: var(--blue); }
.footer-legal {
  font-size: 0.72rem;
  color: var(--gray-4);
  border-top: 1px solid var(--gray-2);
  margin-top: 32px;
  padding-top: 20px;
}

/* =============================================
   BOTTOM NAV — iOS tab bar style
   ============================================= */
.ios-tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 999;
  background: rgba(249,249,249,0.85);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1px solid rgba(0,0,0,0.1);
  padding: 10px 0 20px;
  display: none;
}
@@media (max-width: 767px) { .ios-tab-bar { display: block; } }
.tab-item {
  display: flex; flex-direction: column; align-items: center;
  color: var(--gray-4);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  gap: 3px;
  transition: color 0.15s;
  text-decoration: none;
  position: relative;
}
.tab-item.active, .tab-item:hover { color: var(--blue); }
.tab-item i { font-size: 1.35rem; }
.tab-badge {
  position: absolute;
  top: -2px; right: 8px;
  background: var(--blue);
  color: #fff;
  font-size: 0.5rem;
  font-weight: 700;
  min-width: 14px; height: 14px;
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  padding: 0 3px;
}

/* =============================================
   CATEGORY PILLS — iOS horizontal scroll
   ============================================= */
.category-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding: 4px 0 8px;
  scrollbar-width: none;
}
.category-scroll::-webkit-scrollbar { display: none; }
.cat-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--white);
  border: 1.5px solid var(--gray-2);
  border-radius: 980px;
  padding: 8px 18px;
  font-size: 0.82rem;
  font-weight: 500;
  white-space: nowrap;
  cursor: pointer;
  transition: all 0.2s;
  color: var(--black);
}
.cat-pill.active, .cat-pill:hover {
  background: var(--black);
  color: #fff;
  border-color: var(--black);
}

/* =============================================
   ANIMATIONS
   ============================================= */
.fade-up {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

/* =============================================
   OFFCANVAS — Apple sidebar style
   ============================================= */
.apple-offcanvas .offcanvas-header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--gray-2);
}
.apple-offcanvas .offcanvas-body { padding: 24px; }
.offcanvas-nav-link {
  display: block;
  padding: 14px 0;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--black);
  border-bottom: 1px solid var(--gray-2);
  letter-spacing: -0.02em;
  transition: color 0.15s;
}
.offcanvas-nav-link:hover { color: var(--blue); }

@@media (max-width: 575px) {
  .apple-section { padding: 64px 0; }
  .quick-add { display: none; }
}
</style>
</head>
<body>
<main style="padding-top:56px">

  <!-- ===== PARTIAL: hero.html | data: hero{image_url, heading, subtitle, cta_text, cta_url} ===== -->
  <section class="apple-hero">
    <img class="hero-bg" src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1800&q=85" alt="Hero">
    <div class="hero-vignette"></div>
    <div class="hero-gradient-bottom"></div>

    <div class="hero-text-block">
      <span class="hero-eyebrow">New Season — Spring 2025</span><!-- {{ hero.season_label }} -->
      <h1 class="hero-title">Style that<br>speaks for itself.</h1><!-- {{ hero.heading }} -->
      <p class="hero-subtitle">Meticulously curated pieces for the modern wardrobe.</p><!-- {{ hero.subtitle }} -->
      <div class="hero-actions">
        <a href="#" class="btn-apple-blue px-4 py-3">Shop New Arrivals <i class="bi bi-arrow-right"></i></a>
        <a href="#" class="btn-apple-ghost px-4 py-3">View Collections</a>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="position-absolute bottom-0 mb-4 text-white d-flex flex-column align-items-center" style="opacity:0.45;animation:bounce 2s ease infinite;z-index:2">
      <small style="font-size:0.68rem;letter-spacing:0.1em">SCROLL</small>
      <i class="bi bi-chevron-down mt-1" style="font-size:0.8rem"></i>
    </div>
  </section>
  <!--keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }-->
  <!-- ===== END PARTIAL: hero.html ===== -->


  <!-- ===== PARTIAL: brand-strip.html | data: brands[] ===== -->
  <div class="brand-strip">
    <div class="marquee-track">
      <!-- {% for brand in brands %} — duplicate for seamless loop -->
      <span class="brand-item">VOGUE</span><span class="brand-item">HYPEBEAST</span>
      <span class="brand-item">GQ</span><span class="brand-item">BAZAAR</span>
      <span class="brand-item">COMPLEX</span><span class="brand-item">DAZED</span>
      <span class="brand-item">SSENSE</span><span class="brand-item">MATCHESFASHION</span>
      <span class="brand-item">VOGUE</span><span class="brand-item">HYPEBEAST</span>
      <span class="brand-item">GQ</span><span class="brand-item">BAZAAR</span>
      <span class="brand-item">COMPLEX</span><span class="brand-item">DAZED</span>
      <span class="brand-item">SSENSE</span><span class="brand-item">MATCHESFASHION</span>
      <!-- {% endfor %} -->
    </div>
  </div>
  <!-- ===== END PARTIAL: brand-strip.html ===== -->


  <!-- ===== PARTIAL: category-pills.html | data: categories[] ===== -->
  <div class="bg-white py-4 border-bottom" style="border-color:var(--gray-2)!important">
    <div class="container-xl px-4">
      <!-- {% for cat in categories %} -->
      <div class="category-scroll">
        <div class="cat-pill active"><i class="bi bi-grid-3x3-gap"></i> All</div>
        <div class="cat-pill"><i class="bi bi-bag-heart"></i> Tops</div>
        <div class="cat-pill"><i class="bi bi-scissors"></i> Outerwear</div>
        <div class="cat-pill"><i class="bi bi-gem"></i> Accessories</div>
        <div class="cat-pill">Footwear</div>
        <div class="cat-pill">Bottoms</div>
